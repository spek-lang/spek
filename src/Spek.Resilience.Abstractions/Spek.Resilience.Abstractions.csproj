<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Spek.Resilience</RootNamespace>
    <AssemblyName>Spek.Resilience.Abstractions</AssemblyName>
    <PackageId>Spek.Resilience.Abstractions</PackageId>
    <Description>Contracts for Spek resilience policies (ingress admission control, execution wrappers). Concrete policies — rate limiting, retry, circuit breakers, timeouts, bulkheads — ship in their own packages and depend only on this assembly.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Spek.Tests" />
  </ItemGroup>

</Project>
