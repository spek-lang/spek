<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Add-on package — not part of the initial public package set; flip to true
         (and add to release.yml's manifest) when this add-on ships. -->
    <IsPackable>false</IsPackable>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Spek.Observability.OpenTelemetry</RootNamespace>
    <AssemblyName>Spek.Observability.OpenTelemetry</AssemblyName>
    <PackageId>Spek.Observability.OpenTelemetry</PackageId>
    <Description>OpenTelemetry adapter for Spek's observability surface. Wires the runtime's `IMetricSink` / `IStructuredLogger` calls onto `System.Diagnostics.Metrics.Meter` and `Microsoft.Extensions.Logging`. Trace propagation works through `System.Diagnostics.Activity`, so any OTel-aware tracing pipeline (`OpenTelemetry.Sdk` or `dotnet-trace`) picks up Spek's per-handler spans automatically.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Spek.Observability.Abstractions\Spek.Observability.Abstractions.csproj" />
    <ProjectReference Include="..\Spek.Runtime\Spek.Runtime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Spek.Tests" />
  </ItemGroup>

</Project>
