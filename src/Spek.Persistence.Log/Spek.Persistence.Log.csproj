<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Spek.Persistence.Log</RootNamespace>
    <AssemblyName>Spek.Persistence.Log</AssemblyName>
    <PackageId>Spek.Persistence.Log</PackageId>
    <Description>Append-only segmented snapshot store for Spek actors. Each persist appends a new immutable segment instead of overwriting the previous one — Cassandra-SSTable shape. ISnapshotStore-compatible (existing actors see only the latest segment) plus a richer API for replay-style and event-sourcing patterns.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Spek.Persistence.Abstractions\Spek.Persistence.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Spek.Tests" />
  </ItemGroup>

</Project>
