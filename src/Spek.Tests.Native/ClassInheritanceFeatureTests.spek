// Abstract-class inheritance, behaviorally, in Spek. The C# ClassInheritanceTests
// are white-box (emit shape + Roslyn conformance). This one proves the runtime
// payoff: a template-method base whose concrete method (`Greet`) calls its own
// `abstract` hook (`Salutation`), with the subclass supplying the hook. The
// dispatch to the subclass is the only polymorphism the "reuse + abstract only"
// model needs — everything swappable-at-runtime goes through an `interface`.

using Xunit;

abstract class Greeter
{
    string audience;

    init(string who) { audience = who; }

    // The subclass fills this in; there is no `virtual`/`override` keyword —
    // the emitter infers `override` on the subclass method.
    public abstract string Salutation();

    // Template method — reuse. Calls the abstract hook, which dispatches to
    // whatever concrete subclass is running.
    public string Greet() { return Salutation() + ", " + audience; }
}

class FormalGreeter : Greeter
{
    init(string who) : base(who) { }
    public string Salutation() { return "Good day"; }
}

message DoGreet();
message Greeting(string text);

actor GreetHost
{
    Greeter greeter = new FormalGreeter("world");

    init() { become Active; }

    behavior Active
    {
        on DoGreet => return new Greeting(greeter.Greet());
    }
}

class ClassInheritanceFeatureTests
{
    TestActorSystem sys;

    init() { sys = new TestActorSystem(); }

    public void AbstractTemplateMethodDispatchesToSubclass()
    {
        var probe = sys.CreateProbe();
        var host  = sys.Spawn<GreetHost>();

        probe.Send(host, new DoGreet());
        Greeting g = probe.ExpectMsg<Greeting>(TimeSpan.FromSeconds(10));

        // Base `Greet()` reused verbatim; the `Salutation()` hook resolved to
        // FormalGreeter's implementation.
        Assert.Equal("Good day, world", g.text);
    }
}
