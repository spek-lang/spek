// Ask-with-timeout, in Spek. Converted from the ask half of the C#
// RuntimeErgonomicsTests: an ask with a deadline returns the reply when it arrives
// in time, and — under the "fail fast on all" ask semantics — faults immediately
// with an AskException against a reply-less target instead of hanging out the
// deadline. (The GracefulShutdown tests there are system-level and stay in C#.)

using Xunit;

message Req();
message Resp();

actor Replier
{
    init() { become Active; }
    behavior Active { on Req => return new Resp(); }
}

actor BlackHole
{
    init() { become Active; }
    behavior Active { on Req => { } }   // never replies — the pathological ask target
}

class AskTimeoutTests
{
    TestActorSystem sys;

    init() { sys = new TestActorSystem(); }

    public void AskWithTimeoutRepliesInTime()
    {
        var replier = sys.Spawn<Replier>();

        Resp reply = replier.AskAsync<Resp>(new Req(), TimeSpan.FromSeconds(3));
        Assert.NotNull(reply);
    }

    public void AskWithTimeoutNoReplyFailsFastWithAskException()
    {
        var blackHole = sys.Spawn<BlackHole>();

        // The handler returns without replying, so the ask fails fast with an
        // AskException — no wait for the deadline. The generous window proves it.
        Assert.ThrowsAsync<AskException>(
            () => blackHole.AskAsync<Resp>(new Req(), TimeSpan.FromSeconds(3)).AsTask());
    }
}
