// try/catch/throw flow, in Spek. Converted from the C# TryCatchRuntimeTests: a
// caught exception stays local (the actor keeps processing, no dead-letter); an
// uncaught throw escalates to supervision and dead-letters; typed catch arms route
// by exception type. Dead-letters are observed via a RecordingDeadLetterSink passed
// to the TestActorSystem.

using Xunit;

message DoCaught();
message Recovered();
message HowManyCaught();
message CaughtCount(int v);

message Boom();

message ThrowKind(int kind);
message Caught(string which);

actor Catcher
{
    int caughtCount = 0;

    init() { become Idle; }

    behavior Idle
    {
        on DoCaught =>
        {
            try
            {
                throw new InvalidOperationException("inner");
            }
            catch (InvalidOperationException)
            {
                caughtCount = caughtCount + 1;
                sender.Tell(new Recovered());
            }
        }

        on HowManyCaught => return new CaughtCount(caughtCount);
    }
}

actor Bomb
{
    init() { become Idle; }
    behavior Idle { on Boom => { throw new InvalidOperationException("kaboom"); } }
}

actor Typed
{
    init() { become Idle; }

    behavior Idle
    {
        on ThrowKind k =>
        {
            try
            {
                if (k.kind == 1) { throw new InvalidOperationException("invalid-op"); }
                else            { throw new System.ArgumentException("argument"); }
            }
            catch (InvalidOperationException) { sender.Tell(new Caught("invalid-op")); }
            catch (System.ArgumentException)         { sender.Tell(new Caught("argument")); }
        }
    }
}

class TryCatchTests
{
    Spek.Runtime.RecordingDeadLetterSink sink;
    TestActorSystem sys;

    init()
    {
        sink = new Spek.Runtime.RecordingDeadLetterSink();
        sys  = new TestActorSystem("try-catch", null, sink);
    }

    public void CaughtExceptionStaysLocalActorContinues()
    {
        var probe   = sys.CreateProbe();
        var catcher = sys.Spawn<Catcher>();

        probe.Send(catcher, new DoCaught());
        probe.ExpectMsg<Recovered>(TimeSpan.FromSeconds(2));

        probe.Send(catcher, new HowManyCaught());
        CaughtCount c = probe.ExpectMsg<CaughtCount>(TimeSpan.FromSeconds(2));
        Assert.Equal(1, c.v);

        // The catch swallowed the exception locally — nothing dead-lettered.
        Assert.Empty(sink.Records);
    }

    public void UncaughtThrowEscalatesAndDeadLetters()
    {
        var probe = sys.CreateProbe();
        var bomb  = sys.Spawn<Bomb>();

        probe.Send(bomb, new Boom());

        TestActorSystem.WaitUntilAsync(() => sink.Records.Count > 0, TimeSpan.FromSeconds(2), "dead-letter");

        Assert.NotEmpty(sink.Records);
        Assert.Contains(sink.Records, r => r.Cause is InvalidOperationException);
    }

    public void TypedCatchRoutesByExceptionType()
    {
        var probe = sys.CreateProbe();
        var typed = sys.Spawn<Typed>();

        probe.Send(typed, new ThrowKind(1));
        Caught a1 = probe.ExpectMsg<Caught>(TimeSpan.FromSeconds(2));
        Assert.Equal("invalid-op", a1.which);

        probe.Send(typed, new ThrowKind(2));
        Caught a2 = probe.ExpectMsg<Caught>(TimeSpan.FromSeconds(2));
        Assert.Equal("argument", a2.which);
    }
}
