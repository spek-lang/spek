// Failure directives + dead-letter routing, in Spek. Converted from the expressible
// subset of the C# SupervisionTests: default-Stop terminates + dead-letters with a
// "stopping" reason; messages to a stopped actor dead-letter with "stopped"; an
// OnFailure returning Resume skips the bad message and keeps processing ("resuming").
//
// Restart and Escalate via OnFailure work too, now that
// `FailureDirective.Restart`/`.Escalate`/`.Stop` parse in member-access position.

message Detonate();
message Bump();
message ReadBump();
message BumpValue(int n);

actor DefaultStop
{
    int count = 0;

    init() { become Active; }

    behavior Active
    {
        on Detonate => { throw new System.InvalidOperationException("boom"); }
        on Bump     => { count = count + 1; }
        on ReadBump => return new BumpValue(count);
    }
}

actor Resumer
{
    int count = 0;

    init() { become Active; }

    behavior Active
    {
        on Detonate => { throw new System.InvalidOperationException("boom"); }
        on Bump     => { count = count + 1; }
        on ReadBump => return new BumpValue(count);
    }

    FailureDirective OnFailure(System.Exception ex, object msg) { return FailureDirective.Resume; }
}

actor Restarter
{
    int count = 0;

    init() { become Active; }

    behavior Active
    {
        on Detonate => { throw new System.InvalidOperationException("boom"); }
        on Bump     => { count = count + 1; }
        on ReadBump => return new BumpValue(count);
    }

    FailureDirective OnFailure(System.Exception ex, object msg) { return FailureDirective.Restart; }
}

actor Escalator
{
    init() { become Active; }

    behavior Active { on Detonate => { throw new System.InvalidOperationException("boom"); } }

    FailureDirective OnFailure(System.Exception ex, object msg) { return FailureDirective.Escalate; }
}

class FailureDirectiveTests
{
    Spek.Runtime.RecordingDeadLetterSink sink;
    TestActorSystem sys;

    init()
    {
        sink = new Spek.Runtime.RecordingDeadLetterSink();
        sys  = new TestActorSystem("failure-directive", null, sink);
    }

    public void ExceptionUnderDefaultStopTerminatesAndDeadLetters()
    {
        var worker = sys.Spawn<DefaultStop>();
        worker.Tell(new Detonate());

        TestActorSystem.WaitUntilAsync(() => sink.Records.Count > 0, System.TimeSpan.FromSeconds(2), "failure dead-letter");

        Xunit.Assert.IsType<Detonate>(sink.Records[0].Message);
        Xunit.Assert.IsType<System.InvalidOperationException>(sink.Records[0].Cause);
        Xunit.Assert.Contains("stopping", sink.Records[0].Reason);
        Xunit.Assert.True(sink.Records.Any(r => r.Cause != null));   // LINQ over records (needs System.Linq)
    }

    public void MessagesToAStoppedActorDeadLetter()
    {
        var worker = sys.Spawn<DefaultStop>();
        worker.Tell(new Detonate());
        sys.ExpectStop(worker);

        worker.Tell(new Bump());
        worker.Tell(new Bump());

        TestActorSystem.WaitUntilAsync(() => sink.Records.Count >= 3, System.TimeSpan.FromSeconds(2), "post-stop dead-letters");

        Xunit.Assert.Contains(sink.Records, r => r.Message is Bump && r.Cause == null && r.Reason.Contains("stopped"));
    }

    public void ResumeSkipsBadMessageAndKeepsProcessing()
    {
        var probe  = sys.CreateProbe();
        var worker = sys.Spawn<Resumer>();

        worker.Tell(new Bump());
        worker.Tell(new Detonate());   // throws — Resume skips it
        worker.Tell(new Bump());

        probe.Send(worker, new ReadBump());
        BumpValue v = probe.ExpectMsg<BumpValue>();
        Xunit.Assert.Equal(2, v.n);

        Xunit.Assert.False(worker.IsStopped);
        Xunit.Assert.Contains("resuming", sink.Records[0].Reason);
    }

    public void RestartViaOnFailureResetsInstanceState()
    {
        var probe  = sys.CreateProbe();
        var worker = sys.Spawn<Restarter>();

        worker.Tell(new Bump());      // count 1
        worker.Tell(new Bump());      // count 2
        worker.Tell(new Detonate());  // throws → Restart → fresh instance (count resets)
        worker.Tell(new Bump());      // count 1

        probe.Send(worker, new ReadBump());
        BumpValue v = probe.ExpectMsg<BumpValue>();
        Xunit.Assert.Equal(1, v.n);
        Xunit.Assert.False(worker.IsStopped);
        Xunit.Assert.Contains(sink.Records, r => r.Reason.Contains("restarting"));
    }

    public void EscalateAtRootDegradesToStop()
    {
        var worker = sys.Spawn<Escalator>();
        worker.Tell(new Detonate());

        sys.ExpectStop(worker);
        Xunit.Assert.Contains(sink.Records, r => r.Reason.Contains("escalate at root"));
    }
}
