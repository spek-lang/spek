<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Spek.Testing</RootNamespace>
    <AssemblyName>Spek.Testing</AssemblyName>
    <PackageId>Spek.Testing</PackageId>
    <Description>Testing helpers for Spek actors — TestActorSystem, TestProbe. Rides on xUnit; throws XunitException on assertion failure.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="xunit.assert" Version="2.6.2" />
  </ItemGroup>

  <!-- The schedule-exploration surface (ISchedulePolicy, PCT, ExploreAll) is
       internal while it bakes; the test suite exercises it directly. -->
  <ItemGroup>
    <InternalsVisibleTo Include="Spek.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Spek.Runtime\Spek.Runtime.csproj" />
  </ItemGroup>

</Project>
