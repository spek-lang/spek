bin/
obj/
/packages/
/artifacts/
riderModule.iml
/_ReSharper.Caches/

# Tooling state, user-local config, and private working notes — never committed.
.claude/
.context/
.idea/
/CLAUDE.md
*.user
*.DotSettings.user

# Stray IDE-generated solution / build props at the REPO ROOT. The canonical
# solution is src/Spek.slnx and the shared packaging props is
# src/Directory.Build.props (both tracked); a root copy is always an IDE
# artifact with wrong (root-relative) project paths or stale metadata. Anchored
# with a leading slash so the real files under src/ are untouched.
/Spek.sln
/Spek.slnx
/Directory.Build.props

# Node tooling output (VS Code extension and any future JS tooling).
node_modules/
*.vsix

# Generated parser output (regenerated from .g4 via regenerate.sh).
/src/Spek.Compiler/Grammar/Generated/

# Bundled-on-demand toolchain binaries (regenerate.sh downloads if missing).
/src/Spek.Compiler/Grammar/antlr4-complete.jar

# OS / editor cruft
.DS_Store
.idea/
.vs/

# BenchmarkDotNet run output (regenerated by `dotnet run -c Release` in Spek.Benchmarks)
BenchmarkDotNet.Artifacts/

# spekc output when run without --out (the MSBuild targets emit into obj/ instead)
*.g.cs

# Test-run logs (dotnet test --logger trx)
TestResults/
*.trx
